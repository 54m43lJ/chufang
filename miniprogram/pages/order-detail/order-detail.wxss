.status-row { margin-bottom: 24rpx; }

.section-title { font-size: 28rpx; color: #999; margin-bottom: 12rpx; }

.order-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.order-item:last-child { border-bottom: none; }

.oi-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}
.oi-thumb-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ccc;
}
.oi-thumb-placeholder text:first-child { color: #e74c3c; }

.oi-info { flex: 1; min-width: 0; }
.oi-name { display: block; }
.oi-deleted { color: #ccc; text-decoration: line-through; }
.oi-gone { font-size: 22rpx; color: #e74c3c; }
.oi-qty { color: #666; margin-left: 16rpx; flex-shrink: 0; }

.actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.actions > view { width: 100%; }

.done-hint {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 28rpx;
}
