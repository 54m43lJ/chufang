.container {
  padding: 80rpx 48rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.nickname-input {
  border: 2rpx solid #e74c3c;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 48rpx;
}

.btns {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.btn-primary {
  width: 400rpx;
  padding: 20rpx 0;
  background: #e74c3c;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-skip {
  font-size: 26rpx;
  color: #bbb;
  padding: 12rpx 0;
}
