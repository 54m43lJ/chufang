.container {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lock-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.openid-card {
  width: 100%;
  background: #fff;
  border-radius: 12rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
}

.openid-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.openid-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.openid-value {
  font-size: 26rpx;
  font-family: monospace;
  color: #333;
  word-break: break-all;
  flex: 1;
  margin-right: 16rpx;
}

.toggle-btn {
  font-size: 24rpx;
  color: #e74c3c;
  flex-shrink: 0;
  padding: 4rpx 0;
}

.copy-btn {
  width: 100%;
  background: #e74c3c;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  padding: 18rpx 0;
  text-align: center;
}
.copy-btn:active {
  background: #c0392b;
}

.tip {
  font-size: 24rpx;
  color: #bbb;
  text-align: center;
  line-height: 1.6;
}
