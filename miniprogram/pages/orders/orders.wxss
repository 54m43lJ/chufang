.tab-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}
.tab-row {
  display: flex;
  gap: 8rpx;
}
.tab-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #fff;
  color: #666;
}
.tab-active {
  background: #e74c3c;
  color: #fff;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.order-time {
  font-size: 24rpx;
  color: #999;
}
.order-item {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 28rpx;
}
.oi-name {
  flex: 1;
}
.oi-qty {
  color: #999;
  margin-left: 16rpx;
}

.order-quick-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}
.quick-btn {
  font-size: 24rpx;
  width: 96rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0;
  border-radius: 6rpx;
  text-align: center;
}
.quick-accept { background: #e74c3c; color: #fff; }
.quick-accept:active { background: #c0392b; }
.quick-complete { background: #27ae60; color: #fff; }
.quick-complete:active { background: #1e8449; }
.quick-cancel { background: #fff; color: #999; border: 1rpx solid #ddd; }
.quick-cancel:active { background: #f5f5f5; }
