.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.admin-count-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.admin-count { font-size: 28rpx; color: #999; }
.refresh-icon { font-size: 32rpx; color: #999; }
.header-btns { display: flex; gap: 12rpx; }
.header-btn { padding: 10rpx 22rpx; font-size: 26rpx; }

.user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.user-info { flex: 1; min-width: 0; }
.user-nick { font-size: 30rpx; font-weight: 500; display: block; margin-bottom: 4rpx; }
.user-openid { font-size: 22rpx; color: #bbb; font-family: monospace; word-break: break-all; display: block; margin-bottom: 6rpx; }
.user-role { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 4rpx; display: inline-block; }
.role-user { background: #e8f4fd; color: #0c5460; }
.role-admin { background: #fce4d6; color: #8a3d18; }

.user-actions { display: flex; gap: 16rpx; margin-left: 16rpx; flex-shrink: 0; align-items: center; }
.action-text { font-size: 26rpx; color: #666; }
.action-remove { color: #e74c3c; }

/* 弹窗通用 */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 200;
  display: flex; align-items: center; justify-content: center;
}
.panel {
  width: 580rpx; background: #fff; border-radius: 16rpx; padding: 40rpx; text-align: center;
}
.panel-title { font-size: 34rpx; font-weight: 600; margin-bottom: 24rpx; }

.field-row { text-align: left; margin-bottom: 20rpx; }
.field-label { display: block; font-size: 26rpx; color: #666; margin-bottom: 6rpx; }
.field-input { border: 1rpx solid #ddd; border-radius: 8rpx; padding: 14rpx; font-size: 28rpx; }

.role-select { display: flex; align-items: center; justify-content: center; gap: 16rpx; margin-bottom: 24rpx; }
.role-label { font-size: 28rpx; color: #666; }
.role-btn { font-size: 26rpx; padding: 8rpx 28rpx; border-radius: 6rpx; background: #f5f5f5; color: #666; }
.role-active { background: #e74c3c; color: #fff; }

.form-btns { display: flex; gap: 16rpx; margin-top: 24rpx; }
.form-btns > view { flex: 1; }

.qr-image { width: 400rpx; margin: 0 auto; border-radius: 8rpx; }
.invite-tip { font-size: 24rpx; color: #999; margin-top: 16rpx; }
.qr-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.qr-btn { flex: 1; padding: 14rpx 0; }
.close-btn { margin-top: 16rpx; }
